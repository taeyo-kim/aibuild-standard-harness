{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "sh .github/hooks/run-hook.sh session-start",
        "powershell": "./.github/hooks/run-hook.ps1 session-start",
        "cwd": ".",
        "timeoutSec": 5
      }
    ],
    "sessionEnd": [
      {
        "type": "command",
        "bash": "sh .github/hooks/run-hook.sh session-end",
        "powershell": "./.github/hooks/run-hook.ps1 session-end",
        "cwd": ".",
        "timeoutSec": 5
      },
      {
        "type": "command",
        "bash": "sh .github/hooks/run-hook.sh scan-secrets",
        "powershell": "./.github/hooks/run-hook.ps1 scan-secrets",
        "cwd": ".",
        "env": {
          "SCAN_MODE": "warn",
          "SCAN_SCOPE": "diff"
        },
        "timeoutSec": 30
      }
    ],
    "userPromptSubmitted": [
      {
        "type": "command",
        "bash": "sh .github/hooks/run-hook.sh log-prompt",
        "powershell": "./.github/hooks/run-hook.ps1 log-prompt",
        "cwd": ".",
        "env": {
          "LOG_LEVEL": "INFO"
        },
        "timeoutSec": 5
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "bash": "sh .github/hooks/run-hook.sh tool-guardian",
        "powershell": "./.github/hooks/run-hook.ps1 tool-guardian",
        "cwd": ".",
        "env": {
          "GUARD_MODE": "warn"
        },
        "timeoutSec": 10
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "bash": "sh .github/hooks/run-hook.sh format-lint",
        "powershell": "./.github/hooks/run-hook.ps1 format-lint",
        "cwd": ".",
        "timeoutSec": 30
      }
    ]
  }
}
