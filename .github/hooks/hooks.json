{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "node .github/hooks/scripts/log-session-start.mjs",
        "powershell": "node .github/hooks/scripts/log-session-start.mjs",
        "cwd": ".",
        "timeoutSec": 5
      }
    ],
    "sessionEnd": [
      {
        "type": "command",
        "bash": "node .github/hooks/scripts/log-session-end.mjs",
        "powershell": "node .github/hooks/scripts/log-session-end.mjs",
        "cwd": ".",
        "timeoutSec": 5
      },
      {
        "type": "command",
        "bash": "node .github/hooks/scripts/scan-secrets.mjs",
        "powershell": "node .github/hooks/scripts/scan-secrets.mjs",
        "cwd": ".",
        "env": {
          "SCAN_MODE": "warn",
          "SCAN_SCOPE": "diff"
        },
        "timeoutSec": 30
      }
    ],
    "userPromptSubmitted": [
      {
        "type": "command",
        "bash": "node .github/hooks/scripts/log-prompt.mjs",
        "powershell": "node .github/hooks/scripts/log-prompt.mjs",
        "cwd": ".",
        "env": {
          "LOG_LEVEL": "INFO"
        },
        "timeoutSec": 5
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "bash": "node .github/hooks/scripts/tool-guardian.mjs",
        "powershell": "node .github/hooks/scripts/tool-guardian.mjs",
        "cwd": ".",
        "env": {
          "GUARD_MODE": "warn"
        },
        "timeoutSec": 10
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "bash": "node .github/hooks/scripts/format-lint.mjs",
        "powershell": "node .github/hooks/scripts/format-lint.mjs",
        "cwd": ".",
        "timeoutSec": 30
      }
    ]
  }
}
